# Provider mode: claude | gpt4 | bedrock
POE_PROVIDER_MODE=claude

# Anthropic API (Claude) — separate from Claude Pro subscription
ANTHROPIC_API_KEY=
# Claude Sonnet 4.6 (API id: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI API (GPT-4) — requires platform.openai.com billing
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Inline judges on every /query (uses JUDGE_PROVIDER). Default off — use Score response.
# Set INLINE_EVAL=true to auto-run five judges after each Ask.
INLINE_EVAL=false
JUDGE_PROVIDER=claude

# Voice questions: OpenAI Whisper (uses OPENAI_API_KEY). Local needs pip install -e ".[speech]".
TRANSCRIBE_PROVIDER=openai
TRANSCRIBE_MODEL=

# Daily Ask caps (UTC day, per client IP). Off by default for local unlimited use.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_ASKS_PER_DAY=20

# Operator analytics: one visit per IP per UTC day + every Ask (hashed IP; country if proxy sends it).
OPERATOR_ANALYTICS_ENABLED=true
# Secret for GET /operator/analytics?key=... (empty = dashboard disabled even if logging is on).
OPERATOR_DASHBOARD_KEY=

# Session memory: all turns stored; recent window verbatim + rolling summary for older turns.
SESSION_MEMORY_ENABLED=true
SESSION_MEMORY_RECENT_TURNS=8
SESSION_MEMORY_SUMMARY_ENABLED=true

# API / UI
POE_API_HOST=127.0.0.1
POE_API_PORT=8000
POE_API_BASE_URL=http://127.0.0.1:8000

# Embeddings (local dev)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval
RETRIEVAL_MODE=live
RETRIEVAL_TOP_K=8
HYBRID_RRF_K=60
RERANK_TOP_N=5
LIVE_WIKI_MAX_PAGES=5
LIVE_WIKI_SEARCH_LIMIT=8
LIVE_WIKI_MAX_SEARCH_QUERIES=4
LIVE_WIKI_TITLE_PROBE=true
LIVE_WIKI_TITLE_OVERLAP_FILTER=true
LIVE_WIKI_CACHE_TTL_HOURS=24
LIVE_FALLBACK_MIN_SCORE=0.25
PLANNER_MAX_RETRIEVE_SUBTASKS=4
RETRIEVAL_REFINE_ENABLED=false
RETRIEVAL_REFINE_MIN_SCORE=-1.0
RETRIEVAL_MAX_REFINE_ROUNDS=1

# Paths
POE_DATA_DIR=data
POE_CHROMA_DIR=data/chroma

# AWS Bedrock (optional)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
S3_BUCKET=
S3_PREFIX=poe-wiki-agent/

# Logging
LOG_LEVEL=INFO
