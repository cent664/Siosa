# Provider mode: stub | ollama | claude | gpt4 | bedrock
POE_PROVIDER_MODE=ollama

# Anthropic API (Claude) — separate from Claude Pro subscription
ANTHROPIC_API_KEY=
# Claude Sonnet 4.6 (API id: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI API (GPT-4) — requires platform.openai.com billing
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Inline judges on every /query (uses JUDGE_PROVIDER)
# When using Claude/GPT-4 for answers without local Ollama, set JUDGE_PROVIDER=claude or gpt4
# (or INLINE_EVAL=false to skip judges). Default ollama requires: ollama serve
INLINE_EVAL=true
JUDGE_PROVIDER=ollama

# Show Ollama in provider dropdown (set false on production / Railway)
POE_ENABLE_OLLAMA=true

# Speech-to-text for voice questions in Streamlit (pip install -e ".[speech]" for local)
TRANSCRIBE_PROVIDER=local
TRANSCRIBE_MODEL=

# API / UI
POE_API_HOST=127.0.0.1
POE_API_PORT=8000
POE_API_BASE_URL=http://127.0.0.1:8000

# Ollama (Phase 2+)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# Embeddings (local dev)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval
RETRIEVAL_MODE=live
RETRIEVAL_TOP_K=8
HYBRID_RRF_K=60
RERANK_TOP_N=5
LIVE_WIKI_MAX_PAGES=5
LIVE_WIKI_SEARCH_LIMIT=8
LIVE_WIKI_MAX_SEARCH_QUERIES=4
LIVE_WIKI_TITLE_PROBE=true
LIVE_WIKI_TITLE_OVERLAP_FILTER=true
LIVE_WIKI_CACHE_TTL_HOURS=24
LIVE_FALLBACK_MIN_SCORE=0.25
PLANNER_MAX_RETRIEVE_SUBTASKS=4
RETRIEVAL_REFINE_ENABLED=false
RETRIEVAL_REFINE_MIN_SCORE=-1.0
RETRIEVAL_MAX_REFINE_ROUNDS=1

# Paths
POE_DATA_DIR=data
POE_CHROMA_DIR=data/chroma

# AWS Bedrock (Phase 6)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
S3_BUCKET=
S3_PREFIX=poe-wiki-agent/

# Logging
LOG_LEVEL=INFO
