# Copy these into Railway → Service → Variables (replace ... with real secrets).
# Do not commit real API keys. After saving, Railway redeploys automatically.

# Production profile: INLINE_EVAL=false, OpenAI transcribe
DEPLOYMENT_PROFILE=production

POE_PROVIDER_MODE=claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
TRANSCRIBE_PROVIDER=openai
TRANSCRIBE_MODEL=
JUDGE_PROVIDER=claude
INLINE_EVAL=false
RETRIEVAL_MODE=live
POE_DATA_DIR=/app/data

# Optional public Ask cap (UTC day, per IP). Leave false until you want enforcement.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_ASKS_PER_DAY=20

# Operator analytics (visit once/IP/UTC day + every Ask). Dashboard needs a long random key.
# Attach a Railway volume mounted at /app/data so SQLite survives redeploys.
OPERATOR_ANALYTICS_ENABLED=true
OPERATOR_DASHBOARD_KEY=

# Remove if present: OLLAMA_*, POE_ENABLE_OLLAMA, DEV_UI_ENABLED, custom PORT
