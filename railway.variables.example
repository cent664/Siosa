# Copy these into Railway → Service → Variables (replace ... with real secrets).
# Do not commit real API keys. After saving, Railway redeploys automatically.

POE_PROVIDER_MODE=claude
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
JUDGE_PROVIDER=claude
INLINE_EVAL=false
POE_ENABLE_OLLAMA=false
RETRIEVAL_MODE=live
POE_DATA_DIR=/app/data

# Remove if present: JUDGE_PROVIDER=ollama, OLLAMA_*, custom PORT
